                    src="exposed-dsl/src/main/kotlin/org/example/examples/CustomSelectExamples.kt"
                    include-lines="4-6,9,18-39"/>
        <code-block lang="kotlin"
                    src="exposed-dsl/src/main/kotlin/org/example/examples/CustomSelectExamples.kt"
